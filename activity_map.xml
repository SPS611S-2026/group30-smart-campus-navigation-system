<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_map.xml — Map Screen Layout
    ──────────────────────────────────────
    Layout for MapActivity.java.

    LAYOUT STRUCTURE:
      RelativeLayout (full screen)
        └── FrameLayout       (map area — Person 3 embeds map here)
        └── LinearLayout      (bottom sheet: destination info + buttons)
              └── TextView    (destination name)
              └── TextView    (room + floor)
              └── TextView    (description)
              └── LinearLayout (horizontal row of two buttons)
                    └── Button  (Start Navigation)
                    └── Button  (Stop Navigation)

    NOTE FOR PERSON 3:
    The FrameLayout with id "mapContainer" is reserved for the
    map fragment. Person 3 should either:
      A) Replace it with <fragment android:name="org.osmdroid..."/>
      B) Or programmatically add the MapView/Fragment to it:
         getSupportFragmentManager().beginTransaction()
             .replace(R.id.mapContainer, new YourMapFragment())
             .commit();
-->
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E8EAF6">

    <!-- ── MAP AREA ──────────────────────────────────────────
         This FrameLayout is a placeholder for Person 3's map.
         It fills most of the screen above the bottom panel.
         Person 3: embed your MapView or MapFragment here. -->
    <FrameLayout
        android:id="@+id/mapContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomPanel">

        <!-- Placeholder shown until Person 3 adds the real map -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="🗺️\nMap loads here\n(Person 3)"
            android:gravity="center"
            android:textSize="18sp"
            android:textColor="#9E9E9E" />

    </FrameLayout>

    <!-- ── BOTTOM DESTINATION PANEL ──────────────────────────
         Fixed panel at the bottom of the screen.
         Shows destination info and navigation controls.
         layout_alignParentBottom → always sits at the bottom. -->
    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:elevation="8dp">

        <!-- Destination Name — filled in MapActivity.java -->
        <TextView
            android:id="@+id/tvDestName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Destination Name"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:layout_marginBottom="4dp" />

        <!-- Room + Floor info -->
        <TextView
            android:id="@+id/tvDestRoom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Room · Floor"
            android:textSize="13sp"
            android:textColor="#3F51B5"
            android:layout_marginBottom="4dp" />

        <!-- Description -->
        <TextView
            android:id="@+id/tvDestDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Description"
            android:textSize="13sp"
            android:textColor="#757575"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginBottom="12dp" />

        <!-- Navigation Control Buttons (side by side) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <!-- Start Navigation Button
                 Calls viewModel.startNavigation() in MapActivity.java
                 Disabled once navigation is active (alpha fades it) -->
            <Button
                android:id="@+id/btnStartNav"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="▶ Start"
                android:textSize="14sp"
                android:textStyle="bold"
                android:backgroundTint="#3F51B5"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="6dp" />

            <!-- Stop Navigation Button
                 Calls viewModel.stopNavigation() in MapActivity.java
                 Disabled until navigation starts -->
            <Button
                android:id="@+id/btnStopNav"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="■ Stop"
                android:textSize="14sp"
                android:textStyle="bold"
                android:backgroundTint="#F44336"
                android:textColor="#FFFFFF"
                android:layout_marginStart="6dp"
                android:enabled="false"
                android:alpha="0.5" />

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>
